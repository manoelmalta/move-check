# ─────────────────────────────────────────────────────────────
# MOVE CHECK — Environment Variables Template
# Copy this file to .env.local and fill in the real values.
# NEVER commit .env.local or any file with real secrets.
# ─────────────────────────────────────────────────────────────

# ── Supabase (public — safe to expose in browser bundles) ────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ── Supabase (server-only — NEVER expose to the client) ──────
# Import ONLY in server components, server actions, API routes.
# Never prefix with NEXT_PUBLIC_.
# Never import in files under "use client".
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── App access control ───────────────────────────────────────
# Server-side password gate for the MOVE CHECK interface.
MOVE_CHECK_ACCESS_PASSWORD=your_access_password_here
